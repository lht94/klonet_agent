# Klonet Agent controlled Ops helper.
#
# Install this file as:
#   /etc/sudoers.d/klonet-agent-op
# Validate with:
#   visudo -cf /etc/sudoers.d/klonet-agent-op
#
# Replace %klonet-ops with the Linux group that is allowed to approve Ops
# OperationPlan execution on this server.

Cmnd_Alias KLONET_AGENT_OP = /usr/local/bin/klonet-agent-op restart-screen-component --execute *, \
    /usr/local/bin/klonet-agent-op stop-screen-component --execute *, \
    /usr/local/bin/klonet-agent-op stop-platform-screens --execute *, \
    /usr/local/bin/klonet-agent-op start-platform-screens --execute *, \
    /usr/local/bin/klonet-agent-op install-nginx-config --execute *, \
    /usr/local/bin/klonet-agent-op reload-nginx --execute, \
    /usr/local/bin/klonet-agent-op reload-nginx --execute *, \
    /usr/local/bin/klonet-agent-op read-file --execute *, \
    /usr/local/bin/klonet-agent-op inspect-install-scripts --execute *, \
    /usr/local/bin/klonet-agent-op extract-archive --execute *, \
    /usr/local/bin/klonet-agent-op run-install-script --execute *, \
    /usr/local/bin/klonet-agent-op run-ops-command --execute *, \
    /usr/local/bin/klonet-agent-op ensure-user-group --execute *, \
    /usr/local/bin/klonet-agent-op inspect-docker-containers --execute, \
    /usr/local/bin/klonet-agent-op inspect-docker-containers --execute *, \
    /usr/local/bin/klonet-agent-op start-docker-container --execute *

%klonet-ops ALL=(root) NOPASSWD: KLONET_AGENT_OP
